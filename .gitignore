# Built application files
*.apk
*.ap_

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Kotlin
.kotlin

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
# NOTE: do not add a bare `build/` here — this repo has a top-level `build/`
# skill category (build/configuring-r8-for-compose/) that would be silently
# ignored. Add anchored patterns like `app/build/` or `**/sample-*/build/`
# only if a sample app is added later.
.cxx/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# Intellij
*.iml
/.idea/*
!.idea/codeInsightSettings.xml
app/.idea/
.intellijPlatform/

# DS_Store
*.DS_Store
**/DS_Store

# Keystore files
*.jks

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild

